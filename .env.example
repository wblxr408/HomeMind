# HomeMind Environment Configuration

# Weather API (Open-Meteo - free, no API key required)
# Default location coordinates
WEATHER_LATITUDE=39.9042
WEATHER_LONGITUDE=116.4074
WEATHER_LOCATION_NAME=北京
WEATHER_CACHE_TTL=1800

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# Alternative: use local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Vector Database
CHROMA_PERSIST_DIR=./data/chroma

# Storage Encryption
HOMEMIND_STORAGE_KEY=your-secure-password-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/homemind.log
